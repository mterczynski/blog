---
interface Props {
  title?: string;
  description?: string;
}

const { title, description = "A blog about web programming" } = Astro.props;
const siteTitle = "mterczynski's blog";
const fullTitle = title ? `${title} | ${siteTitle}` : siteTitle;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href={`${base}/styles/global.css`} />
  </head>
  <body>
    <header class="site-header">
      <div class="wrapper">
        <a class="site-title" href={base}>{siteTitle}</a>
        <nav class="site-nav">
          <a href={`${base}/about`}>About</a>
        </nav>
      </div>
    </header>

    <main class="page-content">
      <div class="wrapper">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="wrapper">
        <p>
          &copy; {new Date().getFullYear()} mterczynski &mdash;
          <a href="https://github.com/mterczynski" target="_blank" rel="noopener noreferrer">GitHub</a>
        </p>
      </div>
    </footer>
  </body>
</html>
