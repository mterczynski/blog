---
interface Props {
  title: string;
}
const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <a href={base} class="site-title">mter.pl/blog</a>
        <nav>
          <a href={base}>Home</a>
          <a href={`${base}/about`}>About</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} Michał Terczynski</p>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    line-height: 1.7;
    color: #1a1a2e;
    background: #f8f9fa;
  }

  header {
    background: #1a1a2e;
    color: #fff;
    padding: 0 1rem;
  }

  .header-inner {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .site-title {
    color: #fff;
    text-decoration: none;
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  nav {
    display: flex;
    gap: 1.5rem;
  }

  nav a {
    color: #cdd6f4;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 500;
    transition: color 0.2s;
  }

  nav a:hover {
    color: #fff;
  }

  main {
    max-width: 860px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  footer {
    text-align: center;
    padding: 2rem 1rem;
    color: #666;
    font-size: 0.875rem;
    border-top: 1px solid #e0e0e0;
    margin-top: 3rem;
  }

  a {
    color: #3b82f6;
    text-decoration: none;
  }

  a:hover {
    text-decoration: underline;
  }

  pre {
    background: #1e1e2e !important;
    border-radius: 8px;
    padding: 1.25rem;
    overflow-x: auto;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  code:not(pre code) {
    background: #e8e8f0;
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  h1, h2, h3, h4, h5, h6 {
    line-height: 1.3;
    color: #0f0f23;
  }

  blockquote {
    border-left: 4px solid #3b82f6;
    margin: 1.5rem 0;
    padding: 0.5rem 1rem;
    background: #f0f4ff;
    border-radius: 0 6px 6px 0;
  }
</style>
