---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  date: Date;
}

const { title, date } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<BaseLayout title={title}>
  <article>
    <header class="post-header">
      <h1>{title}</h1>
      <time datetime={date.toISOString()} class="post-date">{formattedDate}</time>
    </header>
    <div class="post-content">
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid #e0e0e0;
  }

  .post-header h1 {
    font-size: 2rem;
    margin: 0 0 0.5rem;
  }

  .post-date {
    color: #666;
    font-size: 0.9rem;
  }

  .post-content {
    max-width: 100%;
  }

  .post-content :global(h2) {
    font-size: 1.6rem;
    margin-top: 2.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .post-content :global(h3) {
    font-size: 1.3rem;
    margin-top: 2rem;
  }

  .post-content :global(h4) {
    font-size: 1.1rem;
    margin-top: 1.5rem;
  }

  .post-content :global(p) {
    margin: 1rem 0;
  }

  .post-content :global(ul), .post-content :global(ol) {
    padding-left: 1.5rem;
  }

  .post-content :global(li) {
    margin: 0.4rem 0;
  }
</style>
