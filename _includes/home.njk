---
layout: base
---

<div class="home">
  <h1 class="page-heading">Posts</h1>

  <ul class="post-list">
    {%- for post in collections.posts | reverse -%}
      <li>
        <span class="post-meta">{{ post.date | postDate }}</span>
        <h2>
          <a class="post-link" href="{{ post.url | url }}">{{ post.data.title }}</a>
        </h2>
      </li>
    {%- endfor -%}
  </ul>
</div>
