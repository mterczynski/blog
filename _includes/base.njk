<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{% if title %}{{ title }} | {{ site.title }}{% else %}{{ site.title }}{% endif %}</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css"
    />
    <style>
      * {
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
          Helvetica, Arial, sans-serif;
        font-size: 16px;
        line-height: 1.5;
        color: #111;
        background: #fdfdfd;
        margin: 0;
      }
      a {
        color: #2a7ae2;
        text-decoration: none;
      }
      a:hover {
        text-decoration: underline;
      }
      .site-header {
        border-top: 5px solid #424242;
        border-bottom: 1px solid #e8e8e8;
        padding: 0 30px;
        min-height: 55.95px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #fdfdfd;
      }
      .site-title {
        font-size: 26px;
        font-weight: 300;
        letter-spacing: -1px;
        color: #424242;
      }
      .site-title:hover {
        text-decoration: none;
        color: #424242;
      }
      .site-nav a {
        margin-left: 20px;
        color: #111;
      }
      .wrapper {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 30px;
      }
      .page-content {
        padding: 30px 0;
      }
      .post-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .post-list li {
        margin-bottom: 30px;
      }
      .post-meta {
        font-size: 14px;
        color: #828282;
      }
      .post-link {
        font-size: 24px;
        font-weight: 300;
        color: #111;
      }
      .post-header {
        margin-bottom: 30px;
      }
      .post-title {
        font-size: 42px;
        letter-spacing: -1px;
        line-height: 1;
        font-weight: 300;
        margin: 0 0 10px;
      }
      .post-content h2 {
        font-size: 28px;
      }
      .post-content h3 {
        font-size: 22px;
      }
      .post-content h4 {
        font-size: 18px;
      }
      code {
        font-family: "Courier New", Courier, monospace;
        font-size: 0.9em;
        background: #eef;
        padding: 1px 4px;
        border-radius: 3px;
      }
      pre {
        overflow-x: auto;
        border-radius: 3px;
      }
      pre code {
        background: none;
        padding: 0;
      }
      .site-footer {
        border-top: 1px solid #e8e8e8;
        padding: 30px;
        color: #828282;
        font-size: 15px;
      }
      img {
        max-width: 100%;
        height: auto;
      }
    </style>
  </head>
  <body>
    <header class="site-header" role="banner">
      <div class="wrapper" style="display: flex; justify-content: space-between; width: 100%; padding: 0;">
        <a class="site-title" href="{{ '/' | url }}">{{ site.title }}</a>
        <nav class="site-nav">
          <a href="{{ '/about/' | url }}">About</a>
        </nav>
      </div>
    </header>
    <main class="page-content" aria-label="Content">
      <div class="wrapper">
        {{ content | safe }}
      </div>
    </main>
    <footer class="site-footer">
      <div class="wrapper">
        &copy; {{ build.year }} {{ site.title }}
      </div>
    </footer>
  </body>
</html>
